    "type": "library",
    "license": "MIT",
    "keywords": [
        "codeigniter4",
        "sms",
        "mutlucell",
        "sanalsantral",
        "netgsm",
        "message",
        "notification"
    ],
    "authors": [
        {
            "name": "Yakup EYİSAN",
            "email": "yakupeyisan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Yakupeyisan\\CodeIgniter4\\Sms\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

